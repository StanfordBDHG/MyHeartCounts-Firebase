{
  "name": "myheartcounts-firebase",
  "version": "4.0.2",
  "license": "MIT",
  "description": "Stanford Biodesign Digital Health MyHeart Counts open-source project",
  "keywords": [
    "Stanford",
    "Biodesign",
    "My heart counts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/StanfordBDHG/MyHeartCounts-Firebase"
  },
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "luxon": "^3.7.2"
  },
  "scripts": {
    "install": "npm --prefix functions install",
    "lint": "npm --prefix functions run lint",
    "lint:fix": "npm --prefix functions run lint:fix",
    "lint:strict": "npm --prefix functions run lint:strict",
    "build": "npm --prefix functions run build",
    "clean": "npm --prefix functions run clean",
    "prepare": "npm run clean && npm run install && npm run build",
    "test:ci": "firebase emulators:exec --only auth,firestore,storage 'npm --prefix functions run test:emulators'",
    "serve": "npm --prefix functions run serve",
    "serve:seeded": "npm --prefix functions run serve:seeded"
  },
  "devDependencies": {
    "@stanfordspezi/spezi-web-configurations": "^0.6.0",
    "@types/luxon": "^3.7.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.4",
    "http-proxy-agent": "^7.0.2"
  }
}